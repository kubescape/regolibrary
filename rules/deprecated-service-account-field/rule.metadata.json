{
    "name": "deprecated-service-account-field",
    "attributes": {
    },
    "ruleLanguage": "Rego",
    "match": [
        {
            "apiGroups": [
                ""
            ],
            "apiVersions": [
                "v1"
            ],
            "resources": [
                "Pod",
                "ReplicationController"
            ]
        },
        {
            "apiGroups": [
                "apps"
            ],
            "apiVersions": [
                "v1"
            ],
            "resources": [
                "Deployment",
                "ReplicaSet",
                "DaemonSet",
                "StatefulSet"
            ]
        },
        {
            "apiGroups": [
                "batch"
            ],
            "apiVersions": [
                "*"
            ],
            "resources": [
                "Job",
                "CronJob"
            ]
        }
    ],
    "ruleDependencies": [
    ],
    "description": "Fails if a workload uses the deprecated serviceAccount field instead of serviceAccountName.",
    "remediation": "Replace serviceAccount with serviceAccountName using the same service account value.",
    "ruleQuery": "armo_builtins"
}
